// Prisma schema for GED Engenharia
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum GlobalRole {
  SYSADMIN      // Dono do SaaS (nós)
  USER          // Utilizador comum logado
}

enum ContractRole {
  GESTOR        // Pode criar/editar documentos e convidar pessoas
  ENGENHEIRO    // Pode submeter novas revisões (R0, R1)
  APROVADOR     // Pode aprovar/rejeitar revisões
  LEITOR        // Só pode visualizar/baixar
}

enum RevisionStatus {
  EM_ELABORACAO
  EM_REVISAO
  APROVADO
  REJEITADO
  OBSOLETO
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

enum Discipline {
  ELETRICA
  HIDRAULICA
  ESTRUTURAL
  MECANICA
  CIVIL
  ARQUITETURA
  OUTRO
}

// NOVO: ÉPICO 4 - Controlo de estado assíncrono para o worker Python
enum TransmittalStatus {
  EM_PROCESSAMENTO // Node registou e enviou para o Python
  CONCLUIDO        // Python terminou de gerar ZIP e PDF no S3
  ERRO             // Falha no processamento pelo worker
}

// --- MODELS ---

model Client {
  id        Int        @id @default(autoincrement())
  nome      String
  cnpj      String?    @unique
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Contract {
  id          Int                  @id @default(autoincrement())
  client      Client               @relation(fields: [clientId], references: [id])
  clientId    Int
  codigo      String               @unique
  nome        String
  descricao   String?
  memberships ContractMembership[]
  documents   Document[]
  
  // Relação Épico 4
  transmittals Transmittal[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model User {
  id                Int                  @id @default(autoincrement())
  nome              String
  email             String               @unique
  senhaHash         String               @map("senha_hash")
  globalRole        GlobalRole           @default(USER)
  
  contracts         ContractMembership[] 
  documentsCreated  Document[]           @relation("UserCreatedDocuments")
  
  requestedApprovals ApprovalWorkflow[]  @relation("UserRequestedApprovals")
  reviewedApprovals  ApprovalWorkflow[]  @relation("UserReviewedApprovals")
  
  // Relação Épico 4
  createdTransmittals Transmittal[]      @relation("UserCreatedTransmittals")

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ContractMembership {
  id         Int          @id @default(autoincrement())
  user       User         @relation(fields: [userId], references: [id])
  userId     Int
  contract   Contract     @relation(fields: [contractId], references: [id])
  contractId Int
  role       ContractRole @default(LEITOR)
  createdAt  DateTime     @default(now())

  @@unique([userId, contractId])
}

model Document {
  id              Int        @id @default(autoincrement())
  contract        Contract   @relation(fields: [contractId], references: [id])
  contractId      Int
  codigoDocumento String     @map("codigo_documento")
  titulo          String
  disciplina      Discipline
  metadata        Json?
  createdBy       User       @relation("UserCreatedDocuments", fields: [createdById], references: [id])
  createdById     Int
  createdAt       DateTime   @default(now())
  revisions       Revision[]

  @@unique([contractId, codigoDocumento])
}

model Revision {
  id               Int               @id @default(autoincrement())
  document         Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId       Int
  versionLabel     String            // Ex: R0, R1, A, B
  filePath         String
  fileHash         String
  status           RevisionStatus    @default(EM_ELABORACAO)
  comments         Json?             // Para futuro Markup/Redlining
  createdAt        DateTime          @default(now())
  
  approvalWorkflow ApprovalWorkflow?

  // Relação Épico 4
  transmittalItems TransmittalItem[]
}

model ApprovalWorkflow {
  id          Int            @id @default(autoincrement())
  revision    Revision       @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId  Int            @unique
  requester   User           @relation("UserRequestedApprovals", fields: [requesterId], references: [id])
  requesterId Int
  reviewer    User?          @relation("UserReviewedApprovals", fields: [reviewerId], references: [id])
  reviewerId  Int?
  status      ApprovalStatus @default(PENDENTE)
  comments    String?        @db.Text
  requestedAt DateTime       @default(now())
  reviewedAt  DateTime?

  @@index([status])
  @@index([requesterId])
}

// --- NOVO MODELO: ÉPICO 4 ---

model Transmittal {
  id          Int               @id @default(autoincrement())
  contract    Contract          @relation(fields: [contractId], references: [id])
  contractId  Int
  codigo      String            
  
  // Novos campos corporativos
  destinatario String?          @db.VarChar(100) // Para quem vai a GRD
  proposito    String           @default("PARA_CONHECIMENTO") // Motivo da Emissão
  
  assunto     String
  mensagem    String?           @db.Text
  
  status      TransmittalStatus @default(EM_PROCESSAMENTO)
  
  zipUrl      String?
  pdfCapaUrl  String?

  createdBy   User              @relation("UserCreatedTransmittals", fields: [createdById], references: [id])
  createdById Int

  items       TransmittalItem[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([contractId, codigo])
  @@index([status])
}

model TransmittalItem {
  id             Int         @id @default(autoincrement())
  transmittal    Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)
  transmittalId  Int
  
  // Ligamos explicitamente à Revisão (o que foi enviado de facto), não ao Documento abstrato.
  revision       Revision    @relation(fields: [revisionId], references: [id])
  revisionId     Int

  // Garante que a mesma revisão não é inserida duas vezes no mesmo Transmittal
  @@unique([transmittalId, revisionId])
}