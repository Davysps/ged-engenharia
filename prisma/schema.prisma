// Prisma schema for GED Engenharia
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum GlobalRole {
  SYSADMIN      // Dono do SaaS (nós)
  USER          // Utilizador comum logado
}

enum ContractRole {
  GESTOR        // Pode criar/editar documentos e convidar pessoas
  ENGENHEIRO    // Pode submeter novas revisões (R0, R1)
  APROVADOR     // Pode aprovar/rejeitar revisões
  LEITOR        // Só pode visualizar/baixar
}

enum RevisionStatus {
  EM_ELABORACAO
  EM_REVISAO
  APROVADO
  REJEITADO
  OBSOLETO
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

enum Discipline {
  ELETRICA
  HIDRAULICA
  ESTRUTURAL
  MECANICA
  CIVIL
  ARQUITETURA
  OUTRO
}

// --- MODELS ---

model Client {
  id        Int        @id @default(autoincrement())
  nome      String
  cnpj      String?    @unique
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Contract {
  id          Int                  @id @default(autoincrement())
  client      Client               @relation(fields: [clientId], references: [id])
  clientId    Int
  codigo      String               @unique
  nome        String
  descricao   String?
  memberships ContractMembership[]
  documents   Document[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model User {
  id                Int                  @id @default(autoincrement())
  nome              String
  email             String               @unique
  senhaHash         String               @map("senha_hash")
  globalRole        GlobalRole           @default(USER)
  
  contracts         ContractMembership[] 
  documentsCreated  Document[]           @relation("UserCreatedDocuments")
  
  // Relacionamentos para o Workflow de Aprovação
  requestedApprovals ApprovalWorkflow[]  @relation("UserRequestedApprovals")
  reviewedApprovals  ApprovalWorkflow[]  @relation("UserReviewedApprovals")
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ContractMembership {
  id         Int          @id @default(autoincrement())
  user       User         @relation(fields: [userId], references: [id])
  userId     Int
  contract   Contract     @relation(fields: [contractId], references: [id])
  contractId Int
  role       ContractRole @default(LEITOR)
  createdAt  DateTime     @default(now())

  @@unique([userId, contractId])
}

model Document {
  id              Int        @id @default(autoincrement())
  contract        Contract   @relation(fields: [contractId], references: [id])
  contractId      Int
  codigoDocumento String     @map("codigo_documento")
  titulo          String
  disciplina      Discipline
  metadata        Json?
  createdBy       User       @relation("UserCreatedDocuments", fields: [createdById], references: [id])
  createdById     Int
  createdAt       DateTime   @default(now())
  revisions       Revision[]

  @@unique([contractId, codigoDocumento])
}

model Revision {
  id               Int               @id @default(autoincrement())
  document         Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId       Int
  versionLabel     String            // Ex: R0, R1, A, B
  filePath         String
  fileHash         String
  status           RevisionStatus    @default(EM_ELABORACAO)
  comments         Json?             // Para futuro Markup/Redlining
  createdAt        DateTime          @default(now())
  
  // Relação 1-para-1 com o motor de Workflow
  approvalWorkflow ApprovalWorkflow? 
}

// --- NOVO MODELO: ÉPICO 3 ---
model ApprovalWorkflow {
  id          Int            @id @default(autoincrement())
  
  // Ligação rigorosa à Revisão
  revision    Revision       @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId  Int            @unique
  
  // Solicitante (ENGENHEIRO ou GESTOR que submeteu)
  requester   User           @relation("UserRequestedApprovals", fields: [requesterId], references: [id])
  requesterId Int
  
  // Aprovador (GESTOR ou APROVADOR que validou/rejeitou)
  reviewer    User?          @relation("UserReviewedApprovals", fields: [reviewerId], references: [id])
  reviewerId  Int?
  
  status      ApprovalStatus @default(PENDENTE)
  comments    String?        @db.Text // Justificativa obrigatória em caso de rejeição
  
  requestedAt DateTime       @default(now()) // Mapeia para dataSolicitacao no Frontend
  reviewedAt  DateTime?

  // Índices para otimizar o filtro do Dashboard
  @@index([status])
  @@index([requesterId])
}